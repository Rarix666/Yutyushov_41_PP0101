<Window x:Class="AISDisciplineDesc.WindowNext"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AISDisciplineDesc"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="WindowNext" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Image Name="ImageButton" Width="100" Height="100" 
               Grid.Row="0" Grid.Column="0" Margin="10"/>
        <Label Name="LabelProfile" Content="Личное дело" FontSize="20" 
               Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="10" PreviewMouseDown="LabelProf_Click"/>
        <Button Name="ButtonExit" Content="Выйти" Width="100" Height="40" Click="ButtonExit_Click" 
                Grid.Row="0" Grid.Column="2" Margin="10" FontSize="22"/>

        <DataGrid Name="DataBaseGrid" 
                  Grid.Row="1" 
                  Grid.ColumnSpan="3" 
                  Margin="10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  RowHeight="NaN">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Выполнено" Click="UpdateOrderStatus_Click" />
                    <MenuItem Header="Открыть" Click="OpenOrderText_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" 
                                    Binding="{Binding Name}" 
                                    Width="*" 
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Дата регистрации" 
                                    Binding="{Binding DateDispatch,  StringFormat=dd.MM.yyyy}" 
                                    Width="*" 
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Срок исполнения" 
                    Binding="{Binding DueDate,  StringFormat=dd.MM.yyyy}" 
                    Width="*" 
                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Отметка о выполнении" 
                    Binding="{Binding Status}" 
                    Width="*" 
                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
