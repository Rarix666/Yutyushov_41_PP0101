<Window x:Class="AISDisciplineDesc.DivisionCommander"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление личными делами" Height="560" Width="780"
        WindowStartupLocation="CenterScreen"
        Loaded="DivisionCommander_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,5,0">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Список сотрудников" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                <DataGrid x:Name="PersonnelDataGrid" Grid.Row="1"
                          AutoGenerateColumns="False"
                          SelectionChanged="PersonnelDataGrid_SelectionChanged"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding name}" Width="*"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding division}" Width="*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding role}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Редактирование" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Grid.Row="0"/>

                    <Label Content="Телефон:" Grid.Row="1" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtPhone" MaxLength="11" PreviewTextInput="txtPhone_PreviewTextInput" Grid.Row="2" Margin="0,2,0,8" Height="32"/>

                    <Label Content="Email:" Grid.Row="3" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtEmail" Grid.Row="4" Margin="0,2,0,8" Height="32"/>

                    <Label Content="Адрес:" Grid.Row="5" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtAddress" Grid.Row="6" Margin="0,2,0,8" Height="45" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <Label Content="Подразделение:" Grid.Row="7" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtDivision" Grid.Row="8" Margin="0,2,0,15" Height="32"/>

                    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                        <Button x:Name="btnUpdate" Content="Обновить" Width="100" Height="35" Margin="0,0,15,0" Click="btnUpdate_Click"/>
                        <Button x:Name="btnClear" Content="Очистить" Width="100" Height="35" Margin="0,0,15,0" Click="btnClear_Click"/>
                        <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
