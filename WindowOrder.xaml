<Window x:Class="AISDisciplineDesc.WindowOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AISDisciplineDesc"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="WindowOrder" Height="450" Width="800">
    <Grid>
        <Label Content="Подразделение:" HorizontalAlignment="Left" Margin="35,30,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="DivCombobox" DisplayMemberPath="name" SelectedValuePath="id" SelectionChanged="Div_SelectChanged" HorizontalAlignment="Left" Margin="139,32,0,0" VerticalAlignment="Top" Width="184"/>
        <DataGrid Name="DataBaseGrid" 
          Margin="10,126,10,10"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          GridLinesVisibility="Horizontal"
          RowHeight="NaN">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" 
                            Binding="{Binding Name}" 
                            Width="*" 
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Дата регистрации" 
                            Binding="{Binding DateDispatch,  StringFormat=dd.MM.yyyy}" 
                            Width="*" 
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Срок исполнения" 
            Binding="{Binding DueDate,  StringFormat=dd.MM.yyyy}" 
            Width="*" 
            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Отметка о выполнении" 
            Binding="{Binding Status}" 
            Width="*" 
            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Click="ButtonExit_Click" Content="Назад" HorizontalAlignment="Left" Margin="685,19,0,0" VerticalAlignment="Top" Height="49" Width="90" FontSize="20"/>

    </Grid>
</Window>
