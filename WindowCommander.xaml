<Window x:Class="AISDisciplineDesc.WindowCommander"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AISDisciplineDesc"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Главное окно" Height="450" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="100" Margin="28,25,0,0" VerticalAlignment="Top" Width="100"/>
        <Button Click="ButtonExit_Click" Content="Выйти" HorizontalAlignment="Left" Margin="683,25,0,0" VerticalAlignment="Top" Height="46" Width="88" FontSize="18"/>
        <Button Click="ButtonOrderForm_Click" Content="Приказы" HorizontalAlignment="Left" Margin="562,25,0,0" VerticalAlignment="Top" Height="46" Width="114" FontSize="18"/>
        <Label Name="LabelName" Content="Личное дело" HorizontalAlignment="Left" Margin="143,53,0,0" VerticalAlignment="Top" FontSize="20" PreviewMouseDown="LabelProf_Click"/>
        <Label Content="Подразделение:" HorizontalAlignment="Left" Margin="42,146,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="DivisionComboBox" DisplayMemberPath="name" SelectedValuePath="id" HorizontalAlignment="Left" Margin="143,148,0,0" VerticalAlignment="Top" Width="152"/>
        <Label Content="Наименование:" HorizontalAlignment="Center" Margin="0,146,0,0" VerticalAlignment="Top"/>
        <TextBox Name="NameOrder" HorizontalAlignment="Left" Margin="453,150,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="165"/>
        <Label Content="Описание:" HorizontalAlignment="Left" Margin="53,199,0,0" VerticalAlignment="Top"/>
        <RichTextBox Name="RichTextOrder" Margin="124,199,124,106">
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <Label Content="Срок исполнения:" HorizontalAlignment="Left" Margin="74,344,0,0" VerticalAlignment="Top"/>
        <TextBox Name="TextDueDate" HorizontalAlignment="Left" Margin="186,348,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button Click="ButtonCreateOrder_Click" Content="Отправить" HorizontalAlignment="Center" Margin="0,373,0,0" VerticalAlignment="Top" Height="29" Width="138"/>
        <Button Click="ButtonOpenCommanders_Click" Content="Личные дела" HorizontalAlignment="Left" Margin="408,25,0,0" VerticalAlignment="Top" Height="46" Width="149" FontSize="18"/>

    </Grid>
</Window>
