<Window x:Class="AISDisciplineDesc.WindowCommander"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AISDisciplineDesc"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Главное окно" Height="450" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="100" Margin="28,25,0,0" VerticalAlignment="Top" Width="100"/>

        <Button Command="{Binding ExitCommand}" Content="Выйти" 
                HorizontalAlignment="Left" Margin="683,25,0,0" VerticalAlignment="Top" Height="46" Width="88" FontSize="18"/>

        <Button Command="{Binding OpenOrdersCommand}" Content="Приказы" 
                HorizontalAlignment="Left" Margin="562,25,0,0" VerticalAlignment="Top" Height="46" Width="114" FontSize="18"/>

        <Label Name="LabelName" Content="{Binding UserName}" 
               HorizontalAlignment="Left" Margin="143,53,0,0" VerticalAlignment="Top" FontSize="20">
            <Label.InputBindings>
                <MouseBinding Gesture="LeftClick" Command="{Binding OpenProfileCommand}"/>
            </Label.InputBindings>
        </Label>

        <Label Content="Подразделение:" HorizontalAlignment="Left" Margin="42,146,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="DivisionComboBox" DisplayMemberPath="name" 
                  ItemsSource="{Binding Divisions}" 
                  SelectedItem="{Binding SelectedDivision}"
                  HorizontalAlignment="Left" Margin="143,148,0,0" VerticalAlignment="Top" Width="152"/>

        <Label Content="Наименование:" HorizontalAlignment="Center" Margin="0,146,0,0" VerticalAlignment="Top"/>
        <TextBox Name="NameOrder" Text="{Binding OrderName, UpdateSourceTrigger=PropertyChanged}" 
                 HorizontalAlignment="Left" Margin="453,150,0,0" TextWrapping="Wrap" 
                 VerticalAlignment="Top" Width="165"/>

        <Label Content="Описание:" HorizontalAlignment="Left" Margin="53,199,0,0" VerticalAlignment="Top"/>
        <RichTextBox x:Name="RichTextOrder" Margin="124,199,124,174">
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>

        <Label Content="Срок исполнения:" HorizontalAlignment="Left" Margin="76,300,0,0" VerticalAlignment="Top"/>
        <TextBox Name="TextDueDate" Text="{Binding DueDate, UpdateSourceTrigger=PropertyChanged}" 
                 HorizontalAlignment="Left" Margin="188,299,0,0" TextWrapping="Wrap" 
                 VerticalAlignment="Top" Width="120"/>

        <Button Command="{Binding CreateOrderCommand}" CommandParameter="{Binding ElementName=RichTextOrder}" 
                Content="Отправить" HorizontalAlignment="Center" Margin="0,373,0,0" 
                VerticalAlignment="Top" Height="29" Width="138"/>

        <Button Command="{Binding OpenPersonnelCommand}" Content="Личные дела" 
                HorizontalAlignment="Left" Margin="596,76,0,0" VerticalAlignment="Top" Height="46" Width="149" FontSize="18"/>
        <Label Content="Файл:" HorizontalAlignment="Left" Margin="505,300,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.861,-0.037"/>
        <TextBox Name="TxtPdfFile" Text="{Binding PdfFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" HorizontalAlignment="Left" Margin="544,299,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Command="{Binding SelectPdfCommand}" Content="Обзор" HorizontalAlignment="Left" Margin="677,300,0,0" VerticalAlignment="Top" Height="28"/>
    </Grid>
</Window>
